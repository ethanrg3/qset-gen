# Copy to .env and fill in. Never commit .env.

# Notion integration token (https://www.notion.so/my-integrations)
NOTION_TOKEN=secret_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Anthropic API key (used by the session extractor)
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Notion database IDs (32-char IDs, hyphenated or not)
NOTION_DB_QUESTIONS=
NOTION_DB_STUDENTS=
NOTION_DB_Q_HISTORY=
NOTION_DB_SESSION_SIGNALS=
NOTION_DB_SKILL_TAXONOMY=
NOTION_DB_SKILL_STATUS_HISTORY=

# FastAPI webhook
# WEBHOOK_BASE_URL is the public URL students' HTML files will POST to.
WEBHOOK_BASE_URL=https://qset-gen.example.com
# Shared secret baked into each generated HTML; checked by the webhook auth middleware.
WEBHOOK_SECRET=change-me-to-a-long-random-string
